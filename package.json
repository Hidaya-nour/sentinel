{
  "name": "sentinel",
  "private": true,
  "workspaces": [
    "api",
    "worker",
    "frontend"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
